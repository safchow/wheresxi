params:query {
}

script:pre-request {
  const token = bru.getEnvVar("auth_token") || bru.getVar("auth_token");

  if (token) {
    req.setHeader("Authorization", `Bearer ${token}`);
  }
}

docs {
  # Get My Bets

  Return the authenticated user's most recent bets.

  **Endpoint:** `GET /api/bets/me`
}

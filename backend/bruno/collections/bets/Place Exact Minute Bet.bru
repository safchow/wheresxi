meta {
  name: Place Exact Minute Bet
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/bets
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

headers {
  Origin: {{client_url}}
}

body:json {
  {
    "marketDayId": "{{market_day_id}}",
    "granularity": "EXACT",
    "exactMinute": {{exact_minute}},
    "wager": 5
  }
}

params:query {
}

docs {
  # Place Exact Minute Bet

  Place a wager on an exact arrival minute.

  **Endpoint:** `POST /api/bets`
}

meta {
  name: Send Market Open Reminder
  type: http
  seq: 2
}

post {
  url: {{base_url}}/api/internal/slack/reminders
  body: json
  auth: none
}

headers {
  Origin: {{client_url}}
  x-internal-slack-secret: {{slack_internal_secret}}
}

body:json {
  {
    "kind": "MARKET_OPEN",
    "date": "{{market_date}}"
  }
}

params:query {
}

docs {
  # Send Market Open Reminder

  Triggers the idempotent internal Slack reminder endpoint. Requires
  `slack_internal_secret` to match `SLACK_INTERNAL_SECRET` on the backend.

  **Endpoint:** `POST /api/internal/slack/reminders`
}

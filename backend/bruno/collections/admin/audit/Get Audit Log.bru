params:query {
}

script:pre-request {
  const token = bru.getEnvVar("auth_token") || bru.getVar("auth_token");

  if (token) {
    req.setHeader("Authorization", `Bearer ${token}`);
  }
}

docs {
  # Get Audit Log

  Return the most recent admin audit entries.

  **Endpoint:** `GET /api/admin/audit`

  Requires an `ADMIN` token.
}

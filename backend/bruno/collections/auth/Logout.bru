meta {
  name: Logout
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/auth/logout
  body: none
  auth: none
}

headers {
  Origin: {{client_url}}
}

params:query {
}

script:pre-request {
  const token = bru.getEnvVar("auth_token") || bru.getVar("auth_token");

  if (token) {
    req.setHeader("Authorization", `Bearer ${token}`);
  }
}

docs {
  # Logout

  Revoke the bearer token used for this request.

  **Endpoint:** `POST /api/auth/logout`
}

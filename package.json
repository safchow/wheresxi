{
  "name": "wheresxi",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "install:all": "npm --prefix frontend install && npm --prefix backend install",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:backend": "npm --prefix backend run lint",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "test:frontend:unit": "npm --prefix frontend run test:unit",
    "test:frontend:e2e": "npm --prefix frontend run test:e2e",
    "test:backend:e2e": "npm --prefix backend run test:e2e",
    "test:backend:e2e:setup": "npm --prefix backend run test:e2e:setup"
  }
}

{
  "name": "wheresxi",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:backend": "pnpm --filter backend lint",
    "typecheck:frontend": "pnpm --filter frontend typecheck",
    "typecheck:backend": "pnpm --filter backend typecheck",
    "test:frontend:unit": "pnpm --filter frontend test:unit",
    "test:frontend:e2e": "pnpm --filter frontend test:e2e",
    "test:backend:e2e": "pnpm --filter backend test:e2e",
    "test:backend:e2e:setup": "pnpm --filter backend test:e2e:setup"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "argon2",
      "prisma"
    ]
  }
}

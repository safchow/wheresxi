TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=please-replace-with-a-32-char-random-string
NODE_ENV=development

DATABASE_URL=postgresql://wheresxi:wheresxi_dev@localhost:5433/wheresxi?schema=public

ACCESS_TOKEN_TTL_DAYS=30
USER_STARTING_CREDITS=500
BANKRUPTCY_RESET_CREDITS=100

# All "current week" + market lock math happens in this zone.
OFFICE_TIMEZONE=America/Toronto

# Allowed origins for CORS. Comma-separated. Defaults to localhost:5173 dev.
ALLOWED_ORIGINS=http://localhost:5173

# Optional: distributed rate limiting via Redis. Falls back to in-memory.
# REDIS_URL=redis://localhost:6379
